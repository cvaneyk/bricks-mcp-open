{
	"description": "4-column services grid with icon, title, text, and link per card",
	"variables": [
		"heading",
		"service1_title", "service1_text", "service1_icon", "service1_url",
		"service2_title", "service2_text", "service2_icon", "service2_url",
		"service3_title", "service3_text", "service3_icon", "service3_url",
		"service4_title", "service4_text", "service4_icon", "service4_url"
	],
	"elements": [
		{
			"id": "sec032",
			"name": "section",
			"parent": 0,
			"children": ["cnt032"],
			"settings": {
				"_background": { "color": { "raw": "#f8f8f8" } },
				"_padding": { "top": "100", "bottom": "100" }
			}
		},
		{
			"id": "cnt032",
			"name": "container",
			"parent": "sec032",
			"children": ["hd032", "gr032"],
			"settings": {
				"_direction": "column",
				"_alignItems": "center"
			}
		},
		{
			"id": "hd032",
			"name": "heading",
			"parent": "cnt032",
			"children": [],
			"settings": {
				"text": "{{heading}}",
				"tag": "h2",
				"_typography": {
					"font-size": "48",
					"font-weight": "700",
					"letter-spacing": "-0.03em",
					"color": { "raw": "#0a0a0a" }
				},
				"_textAlign": "center",
				"_margin": { "bottom": "60" }
			}
		},
		{
			"id": "gr032",
			"name": "container",
			"parent": "cnt032",
			"children": ["sv32a", "sv32b", "sv32c", "sv32d"],
			"settings": {
				"_cssCustom": "%root% { display: grid !important; grid-template-columns: repeat(4, 1fr) !important; gap: 32px !important; width: 100%; } @media (max-width: 991px) { %root% { grid-template-columns: repeat(2, 1fr) !important; } } @media (max-width: 767px) { %root% { grid-template-columns: 1fr !important; } }"
			}
		},
		{
			"id": "sv32a",
			"name": "container",
			"parent": "gr032",
			"children": ["ic32a", "ht32a", "tt32a", "lk32a"],
			"settings": {
				"_direction": "column",
				"_padding": { "top": "32", "right": "28", "bottom": "32", "left": "28" },
				"_background": { "color": { "raw": "#ffffff" } },
				"_border": { "radius": { "top": "12", "right": "12", "bottom": "12", "left": "12" } },
				"_cssCustom": "%root% { transition: transform 0.3s, box-shadow 0.3s; } %root%:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }"
			}
		},
		{
			"id": "ic32a",
			"name": "icon",
			"parent": "sv32a",
			"children": [],
			"settings": {
				"icon": { "library": "themify", "icon": "{{service1_icon}}" },
				"_typography": { "font-size": "32", "color": { "raw": "#0a0a0a" } },
				"_margin": { "bottom": "20" }
			}
		},
		{
			"id": "ht32a",
			"name": "heading",
			"parent": "sv32a",
			"children": [],
			"settings": {
				"text": "{{service1_title}}",
				"tag": "h3",
				"_typography": { "font-size": "22", "font-weight": "600", "color": { "raw": "#0a0a0a" } },
				"_margin": { "bottom": "12" }
			}
		},
		{
			"id": "tt32a",
			"name": "text-basic",
			"parent": "sv32a",
			"children": [],
			"settings": {
				"text": "{{service1_text}}",
				"_typography": { "font-size": "15", "line-height": "1.6", "color": { "raw": "#666666" } },
				"_margin": { "bottom": "20" }
			}
		},
		{
			"id": "lk32a",
			"name": "text-basic",
			"parent": "sv32a",
			"children": [],
			"settings": {
				"text": "<a href=\"{{service1_url}}\">Learn more &rarr;</a>",
				"_typography": { "font-size": "15", "font-weight": "600", "color": { "raw": "#0a0a0a" } },
				"_cssCustom": "%root% a { color: #0a0a0a; text-decoration: none; transition: opacity 0.2s; } %root% a:hover { opacity: 0.6; }"
			}
		},
		{
