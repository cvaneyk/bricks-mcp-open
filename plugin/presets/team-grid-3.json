		{
			"id": "st6001",
			"name": "section",
			"parent": 0,
			"children": [
				"ct6001"
			],
			"settings": {
				"_background": {
					"color": {
						"raw": "#ffffff"
					}
				},
				"_padding": {
					"top": "100",
					"bottom": "100"
				}
			}
		},
		{
			"id": "ct6001",
			"name": "container",
			"parent": "st6001",
			"children": [
				"ht6001",
				"gt6001"
			],
			"settings": {
				"_direction": "column",
				"_alignItems": "center"
			}
		},
		{
			"id": "ht6001",
			"name": "heading",
			"parent": "ct6001",
			"children": [],
			"settings": {
				"text": "{{heading}}",
				"tag": "h2",
				"_typography": {
					"font-size": "48",
					"font-weight": "700",
					"letter-spacing": "-0.03em",
					"color": {
						"raw": "#0a0a0a"
					}
				},
				"_textAlign": "center",
				"_margin": {
					"bottom": "60"
				}
			}
		},
		{
			"id": "gt6001",
			"name": "block",
			"parent": "ct6001",
			"children": [
				"tm6001",
				"tm6002",
				"tm6003"
			],
			"settings": {
				"_display": "grid",
				"_gridTemplateColumns": "repeat(3, 1fr)",
				"_columnGap": "32",
				"_textAlign": "center"
			}
		},
		{
			"id": "tm6001",
			"name": "block",
			"parent": "gt6001",
			"children": [
				"ti6001",
				"tn6001",
				"tr6001"
			],
