{
	"description": "Team members grid with 3 cards, images, names, and roles",
	"variables": [
		"heading",
		"member1_name",
		"member1_role",
		"member1_image",
		"member2_name",
		"member2_role",
		"member2_image",
		"member3_name",
		"member3_role",
		"member3_image"
