					"full": "{{member1_image}}"
				},
				"_border": {
					"radius": {
						"top": "16",
						"right": "16",
						"bottom": "16",
						"left": "16"
					}
				},
				"_cssCustom": "%root% img { width:100%; aspect-ratio:3/4; object-fit:cover; }"
