# Bricks MCP Server — Environment Configuration
# Copy this file to .env and fill in your WordPress credentials.
#
# These are used as a fallback when sites.json is not present.
# For multi-site setups, use sites.json instead (see sites.json.example).

WORDPRESS_URL=https://your-site.com
WORDPRESS_USER=your-username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional: Log level (ERROR, WARN, INFO, DEBUG)
# LOG_LEVEL=INFO
